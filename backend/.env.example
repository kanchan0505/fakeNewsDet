# Backend environment variables

# PostgreSQL database connection URL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fake_news_detection

# API server port
API_PORT=8000

# JWT secret key for signing tokens (change this to a random string in production)
JWT_SECRET_KEY=your-secret-key-change-in-production

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-deployed-frontend.onrender.com

# Public URL of this backend (used to build the Google OAuth redirect_uri)
BACKEND_URL=http://localhost:8000

# Public URL of the frontend (used to redirect after Google login)
FRONTEND_URL=http://localhost:3000

# Google OAuth
# Get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

